Implement pipe(), dup(), dup2() via host_process WASM imports.

Replaces the wasi-libc stubs (which return -ENOSYS or are #ifdef'd out)
with implementations that call our host_process.fd_pipe, host_process.fd_dup,
and host_process.fd_dup2 WASM imports.

Import signatures match wasmvm/crates/wasi-ext/src/lib.rs exactly.

--- a/libc-top-half/musl/include/unistd.h
+++ b/libc-top-half/musl/include/unistd.h
@@ -45,16 +45,16 @@

 #include <bits/alltypes.h>

-#ifdef __wasilibc_unmodified_upstream /* WASI has no pipe */
 int pipe(int [2]);
+#ifdef __wasilibc_unmodified_upstream /* WASI has no pipe2 */
 int pipe2(int [2], int);
 #endif
 int close(int);
 int posix_close(int, int);
-#ifdef __wasilibc_unmodified_upstream /* WASI has no dup */
 int dup(int);
 int dup2(int, int);
+#ifdef __wasilibc_unmodified_upstream /* WASI has no dup3 */
 int dup3(int, int, int);
 #endif
 off_t lseek(int, off_t, int);

--- /dev/null
+++ b/libc-bottom-half/sources/host_pipe_dup.c
@@ -0,0 +1,58 @@
+// Pipe and FD duplication via wasmVM host_process imports.
+//
+// Replaces wasi-libc's ENOSYS stubs with calls to our custom WASM imports:
+//   host_process.fd_pipe  -> pipe()
+//   host_process.fd_dup   -> dup()
+//   host_process.fd_dup2  -> dup2()
+//
+// Import signatures match wasmvm/crates/wasi-ext/src/lib.rs exactly.
+
+#include <__errno.h>
+#include <stdint.h>
+#include <unistd.h>
+
+#define WASM_IMPORT(mod, fn) \
+    __attribute__((__import_module__(mod), __import_name__(fn)))
+
+// host_process.fd_pipe(ret_read_fd: *mut u32, ret_write_fd: *mut u32) -> errno
+WASM_IMPORT("host_process", "fd_pipe")
+uint32_t __host_fd_pipe(uint32_t *ret_read_fd, uint32_t *ret_write_fd);
+
+// host_process.fd_dup(fd: u32, ret_new_fd: *mut u32) -> errno
+WASM_IMPORT("host_process", "fd_dup")
+uint32_t __host_fd_dup(uint32_t fd, uint32_t *ret_new_fd);
+
+// host_process.fd_dup2(old_fd: u32, new_fd: u32) -> errno
+WASM_IMPORT("host_process", "fd_dup2")
+uint32_t __host_fd_dup2(uint32_t old_fd, uint32_t new_fd);
+
+int pipe(int fd[2]) {
+    uint32_t r, w;
+    uint32_t err = __host_fd_pipe(&r, &w);
+    if (err != 0) {
+        errno = (int)err;
+        return -1;
+    }
+    fd[0] = (int)r;
+    fd[1] = (int)w;
+    return 0;
+}
+
+int dup(int fd) {
+    uint32_t new_fd;
+    uint32_t err = __host_fd_dup((uint32_t)fd, &new_fd);
+    if (err != 0) {
+        errno = (int)err;
+        return -1;
+    }
+    return (int)new_fd;
+}
+
+int dup2(int old, int new) {
+    uint32_t err = __host_fd_dup2((uint32_t)old, (uint32_t)new);
+    if (err != 0) {
+        errno = (int)err;
+        return -1;
+    }
+    return new;
+}
