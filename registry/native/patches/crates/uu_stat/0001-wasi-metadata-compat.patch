+// wasmVM: WASI compatibility — provide missing MetadataExt methods
+#[cfg(target_os = "wasi")]
+mod wasi_stat_compat {
+    use std::fs::{FileType, Metadata};
+
+    pub trait MetadataExt {
+        fn mode(&self) -> u32;
+        fn uid(&self) -> u32;
+        fn gid(&self) -> u32;
+        fn blocks(&self) -> u64;
+        fn blksize(&self) -> u64;
+        fn rdev(&self) -> u64;
+    }
+    impl MetadataExt for Metadata {
+        fn mode(&self) -> u32 {
+            let ft = self.file_type();
+            let base = if ft.is_dir() { 0o40755 } else if ft.is_symlink() { 0o120777 } else { 0o100644 };
+            if self.permissions().readonly() { base & !0o222 } else { base }
+        }
+        fn uid(&self) -> u32 { 0 }
+        fn gid(&self) -> u32 { 0 }
+        fn blocks(&self) -> u64 { (self.len() + 511) / 512 }
+        fn blksize(&self) -> u64 { 4096 }
+        fn rdev(&self) -> u64 { 0 }
+    }
+
+    pub trait FileTypeIsExt {
+        fn is_fifo(&self) -> bool;
+    }
+    impl FileTypeIsExt for FileType {
+        fn is_fifo(&self) -> bool { false }
+    }
+}
