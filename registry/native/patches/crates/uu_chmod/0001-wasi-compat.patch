+// wasmVM: WASI compatibility — MetadataExt lacks mode(), Permissions lacks from_mode()
+#[cfg(target_os = "wasi")]
+mod wasi_compat {
+    use std::fs;
+
+    /// Extension trait to provide mode() on WASI Metadata.
+    pub trait MetadataMode {
+        fn mode(&self) -> u32;
+    }
+    impl MetadataMode for fs::Metadata {
+        fn mode(&self) -> u32 {
+            let ft = self.file_type();
+            let base = if ft.is_dir() { 0o755 } else { 0o644 };
+            if self.permissions().readonly() {
+                base & !0o222
+            } else {
+                base
+            }
+        }
+    }
+
+    /// Set POSIX-style permissions on a file (best-effort on WASI).
+    pub fn set_permissions_from_mode(path: &std::path::Path, mode: u32) -> std::io::Result<()> {
+        let mut perms = path.metadata()?.permissions();
+        perms.set_readonly(mode & 0o200 == 0);
+        fs::set_permissions(path, perms)
+    }
+}
+#[cfg(target_os = "wasi")]
+use wasi_compat::MetadataMode;
